# ===================================================
# MANGA BOT - SINGLE ROOT DOCKER ENVIRONMENT FILE
# ===================================================

# ---------------------------------------------------
# 1. API Server (Container: mangabot-api)
# ---------------------------------------------------
API_PORT=9999
MONGODB_URI=mongodb://mongodb:27017/MangaBot
REDIS_URL=redis://redis:6379
JWT_SECRET=your_super_secret_jwt_key
INTERNAL_TOKEN=worker-token
CRAWL_SOURCE_NAME=DiLib
CRAWL_SOURCE_DOMAIN=dilib.vn
GEMINI_API_KEY=your_gemini_api_key

# ---------------------------------------------------
# 2. Crawler Worker (Container: mangabot-worker)
# ---------------------------------------------------
INTERNAL_API_SERVER_URL=http://api-server:9999/api/v1
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ---------------------------------------------------
# 3. Next.js Frontends (Admin Dashboard & User Portal)
# ---------------------------------------------------
# Thay bằng Domain thật của Backend API khi deploy production (Ví dụ: https://api.yourdomain.com/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:9999/api/v1
